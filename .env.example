# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual credentials.

# GitHub PAT — needs repo + read:org scopes for the GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# AWS credentials are read from ~/.aws/credentials via standard credential chain.
# Run `aws configure` to set them up — no env var needed here.
