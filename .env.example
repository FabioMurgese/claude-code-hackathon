# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual credentials.

# --- Auth mode: choose ONE ---

# Option A: Direct Anthropic API (default)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Option B: AWS Bedrock (set CLAUDE_CODE_USE_BEDROCK=1, then run `aws login`)
CLAUDE_CODE_USE_BEDROCK=1
# BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20251001-v1:0  # override if needed

# GitHub PAT — needs repo + read:org scopes for the GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# AWS credentials are loaded from the standard credential chain after `aws login`.
# No static keys needed here — run `aws login` before starting.
